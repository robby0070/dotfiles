[options]
font = Source Code Pro Semibold 11
[colors]
# Base16 Solarized Dark
# Author: Ethan Schoonover (modified by aramisgithub)

foreground          = #ffffff
foreground_bold     = #eee8d5
cursor              = #eee8d5
