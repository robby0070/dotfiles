## POGRAMS ##
super + shift + BackSpace 
	prompt "shut down ?" "poweroff"

super + Return
	$TERMINAL

super + a
	flash_window

super + b
	polybar-msg cmd toggle

super + c
	xcmenuctrl

super + shift + c
	code

super + d
	dmenu_run -i -nb '#1C2023' -sf '#ffffff' -sb '#45C7C4' -nf '#ffffff'

super + shift + d
	deluge

super + i
	$TERMINAL -e htop

super + n
	$TERMINAL -e nmtui

super + shift + n
	$TERMINAL -c Music -e ncmpcpp

super + p
	passmenu -nb '#1C2023' -sf '#ffffff' -sb '#45C7C4' -nf '#ffffff'

control + super + p
	pactl_round_sink.sh

super + shift + p
	pavucontrol

super + shift + q
	qualculate

super + r
	$TERMINAL -e ranger

super + shift + r
	killall sxhkd; sxhkd

super + s
	import "/home/roberto-arch/tmp/screenshot_$(date +%s).png"

super + shift + t
	thunar

super + u
	scratchpad dropdown

super + shift + v
	vlc

super + w
	$BROWSER --incognito

super + shift + w
	$BROWSER

super + shift + z
	zathura $( zenity --file-selection --filename=/home/roberto-arch/doc --file-filter='*.pdf')

#music 

super + backslash ; {space, h, l, shift h, shift l, s, c} 
	mpc {toggle, prev, next, seekthrough -00:00:30, seekthrough +00:00:30, shuffle, clear}
	
super + backslash ; {d} 
	{prompt "rm the current song?" "removesong"}

super + backslash ; {p} 
	{select_playlist, save_playlist} | mpc {load, save}

## MEDIA CONTROL ##

super + m
	pactl set-sink-mute $(pulseaudio_get_default.sh) toggle; update_volume > /tmp/panel-fifo

super + {minus,equal} 
	pactl set-sink-volume @DEFAULT_SINK@ {-,+}5%; update_volume > /tmp/panel-fifo

super + control + {minus,equal} 
	pactl set-sink-volume @DEFAULT_SINK@ {-,+}2% 

super + shift + {minus,equal} 
	xbacklight {-dec,-inc} 5

super + control + shift + {minus,equal} 
	xbacklight {-dec,-inc} 2

## BSPWM CONTROLS ##

# close and kill
super + {_,shift + }q
	bspc node -{c,k}

super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

super + Tab; {h,j,k,l,BackSpace}
	bspc node -p {west,south,north,east,cancel}

super + shift + {y,u,i,o}
	bspc node -z {right -20 0,bottom 0 20,bottom 0 -20,right 20 0}

super + {_,shift + }f
	bspc {desktop -l next,node -t ~fullscreen}

super + space
	bspc node focused -t \~floating

super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} ^{1-9,10}

